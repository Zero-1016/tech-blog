# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# velite
.velite

# generated at build time
/public/sitemap.xml
/public/robots.txt
# IndexNow key file (filename contains the key, written from env at build)
/public/*.txt

# playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# content/tmp 폴더 안의 모든 파일 무시, 단 .gitkeep만 추적
content/tmp/*
!content/tmp/.gitkeep

settings.local.json
# blog-revise 백업
content/posts/.backups/

# blog-write 의 blog-revise 호출 시 임시 저장
content/posts/.tmp/

# blog-validator 백업
.claude/skills/blog-shared/.backups/
# blog-write 로컬 로그
content/tmp/*
!content/tmp/.gitkeep

# blog-write 의 blog-revise 호출 시 임시 저장
content/posts/.tmp/
