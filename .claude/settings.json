{
  "permissions": {
    "allow": ["WebSearch", "Bash(mkdir -p content/tmp)", "Bash(touch content/tmp/.gitkeep)"]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/format-on-save.js"
          }
        ]
      }
    ]
  }
}
